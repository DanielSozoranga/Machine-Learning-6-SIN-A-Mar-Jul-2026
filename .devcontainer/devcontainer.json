{
  "name": "ML Exam — Linear & Logistic Regression (Wine Quality)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-containers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/.DS/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "files.exclude": {
          "**/__pycache__": true,
          "**/.ipynb_checkpoints": true
        }
      }
    }
  },
  "postCreateCommand": "echo 'source /app/.DS/bin/activate' >> ~/.bashrc && echo '✅ Entorno .DS listo. Abre notebooks/exam.ipynb para comenzar.'",
  "remoteUser": "root",
  "forwardPorts": [8888]
}
